# Notification Gateway — copy to .env and adjust (local vs cloud: URLs + secrets only)
NOTIF_GW_PORT=4103
NOTIF_GW_DB_PATH=./notifgw.db
# Base URL this service uses when calling /admin/logs and /admin/health against itself (set to public URL in cloud)
NOTIF_GW_PUBLIC_URL=http://127.0.0.1:4103

REDIS_URL=redis://localhost:6379
INTEL_BASE_URL=http://localhost:4102
DATASCOUT_BASE_URL=http://localhost:4101
MAGICBALL_BASE_URL=http://localhost:4100

JWT_SECRET=dev-only-change-in-production
JWT_EXPIRY=24h

# Mocked channels (unused until real transport is wired)
SMTP_HOST=localhost
SMTP_PORT=1025
SLACK_WEBHOOK_URL=

# After first clone: pnpm --filter notification-gateway seed
# Dev login (users with email): alice@example.com / devpassword
